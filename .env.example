# Copy this file to ".env" and fill in your real keys. Never commit .env.
GEMINI_API_KEY=your_gemini_key_here
OLLAMA_API_KEY=your_ollama_cloud_key_here

# Optional overrides
# LLM_PROVIDER=ollama            # "ollama" (default when OLLAMA_API_KEY set) or "gemini"
# OLLAMA_MODEL=gpt-oss:120b
# GEMINI_MODEL=gemini-2.5-flash

# --- Nightly update / server configuration (all optional) ---
# NIGHTLY_HOUR=2                 # 0-23, local time the nightly rescrape runs (default 2 = 2 AM)
# NIGHTLY_MINUTE=0
# NIGHTLY_ENABLED=1             # set 0 to disable the scheduled nightly job
# SERVER_HOST=0.0.0.0          # bind address (0.0.0.0 = reachable on your LAN)
# SERVER_PORT=5000
# CHROME_PROFILE=               # path to the logged-in Chrome debug profile
# CHROME_DEBUG_PORT=0          # 0 = auto-pick a free port and capture it
